<Window x:Class="Messenger_Project.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Messenger_Project"
        mc:Ignorable="d"
        Title="StartWindow" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" 
           Source="/Resources/Logo.png" 
           Width="120" 
           Height="120" 
           Margin="20"
           HorizontalAlignment="Center"
           Stretch="Uniform"/>
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center">

            <TextBlock Text="Welcome to Messenger" 
                       FontSize="24" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,40" 
                       HorizontalAlignment="Center"/>

            <Button Content="Login" 
                    Height="50" 
                    Width="250" 
                    Margin="0,0,0,15"
                    FontSize="16"
                    Click="Login_Button_Click"/>

            <Button Content="Register" 
                    Height="50" 
                    Width="250" 
                    FontSize="16"
                    Click="Register_Button_Click"/>
            <!-- Cursor="Hand" Для відображення курсору при наведенні на текст-->
            <TextBlock Text="Forgot password?" 
                       Foreground="Gray" 
                       Margin="0,20,0,0" 
                       HorizontalAlignment="Center" 
                       Cursor="Hand" 
                       MouseDown="ForgotPassword_MouseDown"/>
            

        </StackPanel>
        <!-- Для футтеру -->
        <TextBlock Grid.Row="2" 
                   HorizontalAlignment="Center" 
                   Foreground="LightGray"/>
    </Grid>
</Window>
