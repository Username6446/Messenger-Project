<Window x:Class="Messenger_Project.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sign up" Height="381" Width="391"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="20" VerticalAlignment="Center">

        <TextBlock Text="Username" Height="17"/>
        <TextBox x:Name="UsernameBox" Height="33" RenderTransformOrigin="0.5,0.5">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0.234"/>
                    <RotateTransform/>
                    <TranslateTransform X="-0.004"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>

        <TextBlock Text="Password" Height="18"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,4,0,10" Height="33"/>

        <TextBlock Text="Repeat password" Height="17"/>
        <PasswordBox x:Name="RepeatPasswordBox" Margin="0,4,0,14" Height="33"/>

        <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="Collapsed" Margin="0,0,0,10"/>
        <Button Content="Sign up" Click="RegisterButton_Click" Height="23" Width="140" RenderTransformOrigin="0.571,0.534"/>

    </StackPanel>
</Window>
